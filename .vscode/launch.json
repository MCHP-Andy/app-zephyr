{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MEC1757 APP Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",

            // Openocd path
            "serverpath": "${workspaceFolder}/tools/openocd-v0.12.0-i686-w64-mingw32/bin/openocd.exe",
            // GDB path
            "gdbPath": "${workspaceFolder}/../zephyr_main/zephyr-sdk-0.16.8/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb.exe",

            // For single debug
            "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",

            "configFiles": [
                "interface/jlink.cfg",
                // "interface/cmsis-dap.cfg",

                "${workspaceFolder}/tools/mec1753_ram.cfg"
            ],
            "overrideLaunchCommands": [
                "monitor reset halt",

                // For single debug
                "load",

                // 1. Parse the vector table in GDB
                "set $v_addr = &_vector_table",
                "set $v_msp = *(unsigned int*)$v_addr",
                "set $v_pc = *(unsigned int*)($v_addr + 4)",

                // 2. Sync REGs
                "set $sp = $v_msp",
                "set $pc = $v_pc",

                // 3. Print the value
                "monitor echo --------------------------------------",
                "eval \"monitor echo Vector_Table:_0x%08X\", $v_addr",
                "eval \"monitor echo MSP_Value:____0x%08X\", $v_msp",
                "eval \"monitor echo PC_Value:_____0x%08X\", $v_pc",
                "monitor echo --------------------------------------",

                "monitor echo \"Ready to debug from RAM\"",

                // 4. Break point in main
                // "thbreak main"
            ],

            "postStartSessionCommands": [
                "monitor resume"
            ],
            // "runToEntryPoint": "main",

            // "showDevDebugOutput": "raw"
        },
        {
            "name": "MEC1757 SYS Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",

            // Openocd path
            "serverpath": "${workspaceFolder}/tools/openocd-v0.12.0-i686-w64-mingw32/bin/openocd.exe",
            // GDB path
            "gdbPath": "${workspaceFolder}/../zephyr_main/zephyr-sdk-0.16.8/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb.exe",

            // For whole system(bootloader+app)
            "executable": "${workspaceFolder}/build/app/zephyr/zephyr.elf",

            "configFiles": [
                "interface/jlink.cfg",
                // "interface/cmsis-dap.cfg",

                "${workspaceFolder}/tools/mec1753_ram.cfg"
            ],
            "overrideLaunchCommands": [
                "monitor reset halt",

                // For whole system(bootloader+app)
                "monitor load_image build/bootloader/zephyr/zephyr.elf",
                "monitor load_image build/app/zephyr/zephyr.elf",

                "monitor mem2array vtable 32 0x000B0000 2",
                "monitor reg msp $vtable(0)",
                "monitor reg pc $vtable(1)",
                "monitor echo \"Ready to debug from RAM\"",
                "thbreak main"
            ],

            // "postStartSessionCommands": [
            //     "monitor resume"
            // ],
            // "runToEntryPoint": "main",

            // "showDevDebugOutput": "raw"
        }
    ]
}
